<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Metro.ReservationController">
    <children>
        <VBox layoutX="61.0" layoutY="57.0" prefHeight="386.0" prefWidth="478.0" spacing="10.0">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <Label text="Name:" />
                        <TextField fx:id="txtname" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label text="Departure Station:" />
                        <ComboBox fx:id="txtdstation" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label text="Arrival Station:" />
                        <ComboBox fx:id="txtastation" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label text="Metro Number:" />
                        <TextField fx:id="txtmnumber" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label text="Metro Name:" />
                        <TextField fx:id="txtmline" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label text="Price:" />
                        <TextField fx:id="txtprice" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label text="Date:" />
                        <DatePicker fx:id="txtdate" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label text="Numbers of tickets:" />
                        <TextField fx:id="txtticket" />
                    </children>
                </HBox>
                <Button fx:id="btnReserve" text="Reserve" onAction="#reserve"/>
                <Button fx:id="btnSearch" text="Search" onAction="#load"/>
            </children>
        </VBox>
    </children>
</AnchorPane>

